# ─── Database (Kitchen Helper) ────────────────────────────────────────────────
POSTGRES_USER=kitchen_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=kitchen_helper

# ─── Backend ─────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_random_secret_key
DEFAULT_CURRENCY=EUR

# ─── Logto Auth ──────────────────────────────────────────────────────────────
# LOGTO_ENDPOINT = public auth URL (used by backend for JWKS token validation)
# LOGTO_APP_ID   = SPA app ID from Logto admin console
LOGTO_ENDPOINT=https://auth.homebud.net
LOGTO_APP_ID=5azr3e6i4fb62r35x6uaa

# ─── OpenAI (for receipt scanning + AI chef) ────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key

# ─── Frontend (Vite build args — baked in at build time) ────────────────────
# Empty VITE_API_URL = same origin (nginx proxies /api/* to backend). No CORS issues.
VITE_API_URL=
VITE_LOGTO_ENDPOINT=https://auth.homebud.net
VITE_LOGTO_APP_ID=5azr3e6i4fb62r35x6uaa

# ─── CORS / URLs ────────────────────────────────────────────────────────────
FRONTEND_URL=https://homebud.net
